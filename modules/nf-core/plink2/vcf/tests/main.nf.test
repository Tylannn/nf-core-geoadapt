nextflow_process {

    name "Test Process PLINK2_VCF"
    script "../main.nf"
    process "PLINK2_VCF"

    tag "modules"
    tag "modules_nfcore"
    tag "plink2"
    tag "plink2/vcf"

    test("test_plink2_vcf") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/vcf/test.vcf.gz', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}